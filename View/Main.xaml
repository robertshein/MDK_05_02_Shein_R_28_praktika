<Page x:Class="praktika28_Shein.View.Main"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:praktika28_Shein.View"
      xmlns:elements="clr-namespace:praktika28_Shein.View.Items"
      mc:Ignorable="d"
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Main">
    <Page.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF2DD61B"/>
            <Setter Property="BorderBrush" Value="#FF2DD61B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10,10,10,5">
            <Label Content="Поиск:" VerticalAlignment="Center" FontSize="14"/>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" 
                     Width="200" Margin="5,0,0,0" 
                     VerticalAlignment="Center" 
                     FontSize="12"
                     Padding="5,2"/>
        </StackPanel>

        <ListView Grid.Row="1" 
                  ItemsSource="{Binding Tasks}" 
                  HorizontalContentAlignment="Stretch" 
                  Margin="0,0,0,5">
            <ListView.ItemTemplate>
                <DataTemplate>
                    <elements:Item DataContext="{Binding}"/>
                </DataTemplate>
            </ListView.ItemTemplate>
        </ListView>

        <Button Grid.Row="2" 
                Style="{StaticResource Update}"
                Command="{Binding OnAddTask}"
                Content="Добавить"
                Height="25"
                Width="70"
                HorizontalAlignment="Right"
                Margin="0,0,10,10">
            <Button.Effect>
                <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
            </Button.Effect>
        </Button>
    </Grid>
</Page>