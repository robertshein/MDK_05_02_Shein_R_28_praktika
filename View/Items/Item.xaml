<UserControl x:Class="praktika28_Shein.View.Items.Item"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:praktika28_Shein.View.Items"
             mc:Ignorable="d"
             FontFamily="Bahnschrift Light Condensed">
    <UserControl.Resources>
        <Style TargetType="Button" x:Key="Update">
            <Setter Property="Background" Value="#FF2DD61B"/>
            <Setter Property="BorderBrush" Value="#FF2DD61B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
        <Style TargetType="Button" x:Key="Delete">
            <Setter Property="Background" Value="#FFD62F1B"/>
            <Setter Property="BorderBrush" Value="#FFD62F1B"/>
            <Setter Property="Foreground" Value="White"/>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10" Background="White">
        <Grid.Effect>
            <DropShadowEffect Opacity="0.1"/>
        </Grid.Effect>

        <Image Width="40" Height="40" Margin="10" VerticalAlignment="Top" HorizontalAlignment="Left"
               Source="/Images/ic-task.png"/>

        <Grid Margin="60,0,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="270"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="10,0,10,0">
                <Grid Margin="0,0,0,10" Height="60" VerticalAlignment="Top" Background="White">
                    <Grid.Effect>
                        <DropShadowEffect Opacity="0.1"/>
                    </Grid.Effect>
                    <Label Content="Наименование:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                    <TextBox Text="{Binding Name}"
                             IsEnabled="{Binding IsEnable}"
                             VerticalContentAlignment="Center"
                             Margin="10,25,10,0"
                             VerticalAlignment="Top"
                             Height="25"/>
                </Grid>

                <Grid Height="60" VerticalAlignment="Top" Background="White">
                    <Grid.Effect>
                        <DropShadowEffect Opacity="0.1"/>
                    </Grid.Effect>
                    <Label Content="Приоритет:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                    <ComboBox ItemsSource="{Binding DataContext.Priorities, RelativeSource={RelativeSource AncestorType=Page}}"
              DisplayMemberPath="Name"
              SelectedValuePath="Id"
              SelectedValue="{Binding PriorityId, UpdateSourceTrigger=PropertyChanged}"
              IsEnabled="{Binding IsEnable}"
              Margin="10,25,10,0"
              VerticalAlignment="Top"
              Height="25"/>
                </Grid>
            </StackPanel>

            <StackPanel Grid.Column="1" Margin="10,0,10,0">
                <Grid Height="60" VerticalAlignment="Top" Background="White">
                    <Grid.Effect>
                        <DropShadowEffect Opacity="0.1"/>
                    </Grid.Effect>
                    <Label Content="Срок выполнения:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                    <DatePicker SelectedDate="{Binding DateExecute}"
                                IsEnabled="{Binding IsEnable}"
                                Margin="10,25,10,0"
                                VerticalAlignment="Top"
                                Height="25"/>
                </Grid>

                <Grid Height="60" VerticalAlignment="Top" Background="White">
                    <Grid.Effect>
                        <DropShadowEffect Opacity="0.1"/>
                    </Grid.Effect>
                    <Label Content="Комментарий:" VerticalAlignment="Top" Margin="10,0,10,0"/>
                    <TextBox Text="{Binding Comment}"
                             IsEnabled="{Binding IsEnable}"
                             VerticalContentAlignment="Center"
                             Margin="10,25,10,0"
                             VerticalAlignment="Top"
                             Height="25"/>
                </Grid>
            </StackPanel>
        </Grid>

        <!-- Buttons -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"
                    VerticalAlignment="Top" Margin="0,145,10,0">
            <Button Style="{StaticResource Update}"
                    Command="{Binding OnEdit}"
                    Content="{Binding IsEnableText}"
                    Height="25"
                    Width="70"
                    Margin="0,0,5,0">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
            <Button Style="{StaticResource Update}"
                    Command="{Binding OnDone}"
                    Content="{Binding IsDoneText}"
                    Height="25"
                    Width="70"
                    Margin="0,0,5,0">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
            <Button Style="{StaticResource Delete}"
                    Command="{Binding OnDelete}"
                    Content="Удалить"
                    Height="25"
                    Width="70">
                <Button.Effect>
                    <DropShadowEffect Opacity="0.5" BlurRadius="3" ShadowDepth="3"/>
                </Button.Effect>
            </Button>
        </StackPanel>
    </Grid>
</UserControl>